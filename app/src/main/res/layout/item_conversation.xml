<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="14dp"
    android:background="?attr/selectableItemBackground">

    <View
        android:id="@+id/view_online"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10dp"
        android:background="@drawable/online_dot"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_conv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/view_online"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_conv_badge"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignParentEnd="true"
        android:background="@drawable/badge_bg"
        android:gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_conv_last"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_conv_name"
        android:layout_toEndOf="@id/view_online"
        android:layout_toStartOf="@id/tv_conv_badge"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#99FFFFFF"
        android:textSize="13sp" />

</RelativeLayout>
